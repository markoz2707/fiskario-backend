model KPiREntry {
  id                String        @id @default(cuid())
  tenant_id         String
  company_id        String

  lp                Int           // Lp. (kolumna 1)
  entryDate         DateTime      // Data zdarzenia gosp. (kol. 2)
  documentNumber    String        // Nr dowodu ksiegowego (kol. 3)
  counterpartyName  String?       // Nazwa kontrahenta (kol. 4)
  counterpartyAddress String?     // Adres kontrahenta (kol. 5)
  description       String        // Opis zdarzenia (kol. 6)

  salesRevenue      Float         @default(0) // Przychod ze sprzedazy (kol. 7)
  otherRevenue      Float         @default(0) // Pozostale przychody (kol. 8)
  totalRevenue      Float         @default(0) // Razem przychod (kol. 9 = 7+8)

  purchaseCost      Float         @default(0) // Zakup towarow/materialow (kol. 10)
  sideExpenses      Float         @default(0) // Koszty uboczne zakupu (kol. 11)
  salaries          Float         @default(0) // Wynagrodzenia (kol. 12)
  otherExpenses     Float         @default(0) // Pozostale wydatki (kol. 13)
  totalExpenses     Float         @default(0) // Razem wydatki (kol. 14 = 10+11+12+13)

  otherColumn       String?       // Wolna kolumna (kol. 15)
  researchCosts     Float         @default(0) // Koszty B+R (kol. 16)
  comments          String?       // Uwagi (kol. 17)

  sourceType        String        // INVOICE_SALES, INVOICE_PURCHASE, MANUAL, ZUS_CONTRIBUTION, DEPRECIATION, SALARY, OTHER
  sourceId          String?       // ID faktury/dokumentu zrodlowego
  month             Int
  year              Int
  isCorrection      Boolean       @default(false)
  correctedEntryId  String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  company           Company       @relation(fields: [company_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
  @@index([year, month])
  @@index([sourceType])
  @@index([sourceId])
  @@index([entryDate])
}

model Remanent {
