generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

model User {
  id                String   @id @default(cuid())
  tenant_id         String
  email             String   @unique
  password          String?
  passwordEncrypted String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  roles             Role[]   @relation("RoleToUser")

  @@index([tenant_id])
}

model Role {
  id          String       @id @default(cuid())
  tenant_id   String
  name        String
  permissions Permission[] @relation("PermissionToRole")
  users       User[]       @relation("RoleToUser")

  @@index([tenant_id])
}

model Permission {
  id    String @id @default(cuid())
  name  String @unique
  roles Role[] @relation("PermissionToRole")
}

model Company {
  id                    String                 @id @default(cuid())
  tenant_id             String
  name                  String
  nip                   String?
  nipEncrypted          String?
  address               Json?
  taxForm               String?
  vatPayer              Boolean                @default(false)
  isActive              Boolean                @default(true)
  regon                 String?
  taxOffice             String?
  vatStatus             String?
  auditLogs             AuditLog[]
  taxSettings           CompanyTaxSettings[]
  dpiaDocuments         DPIADocument[]
  declarations          Declaration[]
  digitalCertificates   DigitalCertificate[]
  invoices              Invoice[]
  profilZaufanyProfiles ProfilZaufanyProfile[]
  signatureRecords      SignatureRecord[]
  taxCalculations       TaxCalculation[]
  vatRegisters          VATRegister[]
  zusContributions      ZUSContribution[]
  zusEmployees          ZUSEmployee[]
  zusRegistrations      ZUSRegistration[]
  zusReports            ZUSReport[]
  zusSubmissions        ZUSSubmission[]
  apiCredentials        CompanyApiCredentials[]
  kpirEntries           KPiREntry[]
  remanents             Remanent[]
  fixedAssets           FixedAsset[]
  depreciationEntries   DepreciationEntry[]
  annualTaxReturns      AnnualTaxReturn[]
  employmentIncomes     EmploymentIncome[]
  chatConversations     ChatConversation[]

  @@index([tenant_id])
}

model Buyer {
  id           String    @id @default(cuid())
  tenant_id    String
  name         String
  nip          String?
  nipEncrypted String?
  address      String?
  city         String?
  postalCode   String?
  country      String    @default("PL")
  email        String?
  phone        String?
  website      String?
  notes        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invoices     Invoice[]

  @@index([tenant_id])
  @@index([nip])
  @@index([isActive])
}

model Invoice {
  id                  String        @id @default(cuid())
  tenant_id           String
  company_id          String
  number              String
  series              String
  date                DateTime
  dueDate             DateTime?
  totalNet            Float
  totalVat            Float
  totalGross          Float
  status              String        @default("draft")
  pdfUrl              String?
  ksefStatus          String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  buyer_id            String?
  approvalNotes       String?
  approvalStatus      String?
  approvedAt          DateTime?
  approvedBy          String?
  currency            String?       @default("PLN")
  exchangeRate        Float?
  isIncoming          Boolean       @default(false)
  ksefDownloadDate    DateTime?
  ksefInvoiceNumber   String?       @unique
  ksefReferenceNumber String?
  ksefSellerNip       String?
  ksefSubmittedAt     DateTime?
  ksefUpoNumber       String?
  ksefXmlContent      String?
  paymentMethod       String?
  receivedFromKsef    Boolean       @default(false)
  rejectionReason     String?
  type                String?       @default("standard") // 'standard' | 'correction' | 'advance' | 'proforma'
  correctionOf        String?       // ID of original invoice for corrections
  correctionReason    String?       // Reason for correction
  splitPayment        Boolean       @default(false) // Mechanizm podzielonej płatności (MPP)
  splitPaymentAmount  Float?        // Kwota MPP (VAT amount for split payment)
  buyer               Buyer?        @relation(fields: [buyer_id], references: [id])
  company             Company       @relation(fields: [company_id], references: [id])
  items               InvoiceItem[]

  @@index([tenant_id])
  @@index([buyer_id])
  @@index([ksefInvoiceNumber])
  @@index([receivedFromKsef])
  @@index([isIncoming])
  @@index([approvalStatus])
  @@index([ksefStatus])
  @@index([correctionOf])
  @@index([type])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoice_id  String
  description String
  quantity    Float
  unitPrice   Float
  vatRate     Float
  gtu         String?
  netAmount   Float
  vatAmount   Float
  grossAmount Float
  invoice     Invoice @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
}

model Declaration {
  id            String    @id @default(cuid())
  tenant_id     String
  company_id    String
  type          String
  period        String
  variant       String?
  data          Json
  status        String    @default("draft")
  submittedAt   DateTime?
  upoNumber     String?
  upoDate       DateTime?
  xmlContent    String?
  signatureType String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       Company   @relation(fields: [company_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
  @@index([type])
  @@index([period])
}

model ZUSEmployee {
  id                 String            @id @default(cuid())
  tenant_id          String
  company_id         String
  pesel              String?
  peselEncrypted     String?
  firstName          String
  lastName           String
  birthDate          DateTime
  address            String
  phone              String?
  email              String?
  employmentDate     DateTime
  terminationDate    DateTime?
  insuranceStartDate DateTime
  isOwner            Boolean           @default(false)
  contractType       String
  salaryBasis        Float
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  zusContributions   ZUSContribution[]
  company            Company           @relation(fields: [company_id], references: [id])
  zusRegistrations   ZUSRegistration[]

  @@index([tenant_id])
  @@index([company_id])
  @@index([pesel])
}

model ZUSRegistration {
  id                 String      @id @default(cuid())
  tenant_id          String
  company_id         String
  employee_id        String
  formType           String
  registrationDate   DateTime
  insuranceTypes     Json
  contributionBasis  Float
  status             String      @default("draft")
  zusReferenceNumber String?
  upoNumber          String?
  upoDate            DateTime?
  submittedAt        DateTime?
  data               Json
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  company            Company     @relation(fields: [company_id], references: [id])
  employee           ZUSEmployee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([company_id])
  @@index([employee_id])
  @@index([formType])
}

model ZUSReport {
  id                 String            @id @default(cuid())
  tenant_id          String
  company_id         String
  reportType         String
  period             String
  reportDate         DateTime
  totalEmployees     Int               @default(0)
  totalContributions Float             @default(0)
  status             String            @default("draft")
  zusReferenceNumber String?
  upoNumber          String?
  upoDate            DateTime?
  submittedAt        DateTime?
  data               Json
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  contributions      ZUSContribution[]
  company            Company           @relation(fields: [company_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
  @@index([reportType])
  @@index([period])
}

model ZUSContribution {
  id                     String       @id @default(cuid())
  tenant_id              String
  company_id             String
  employee_id            String?
  report_id              String?
  period                 String
  contributionDate       DateTime
  emerytalnaEmployer     Float        @default(0)
  emerytalnaEmployee     Float        @default(0)
  rentowaEmployer        Float        @default(0)
  rentowaEmployee        Float        @default(0)
  chorobowaEmployee      Float        @default(0)
  wypadkowaEmployer      Float        @default(0)
  zdrowotnaEmployee      Float        @default(0)
  zdrowotnaDeductible    Float        @default(0)
  fpEmployee             Float        @default(0)
  fgspEmployee           Float        @default(0)
  basisEmerytalnaRentowa Float        @default(0)
  basisChorobowa         Float        @default(0)
  basisZdrowotna         Float        @default(0)
  basisFPFGSP            Float        @default(0)
  zusFormType            String?
  status                 String       @default("calculated")
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  company                Company      @relation(fields: [company_id], references: [id])
  employee               ZUSEmployee? @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  report                 ZUSReport?   @relation(fields: [report_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([company_id])
  @@index([employee_id])
  @@index([period])
}

model ZUSSubmission {
  id          String    @id @default(cuid())
  tenant_id   String
  company_id  String
  period      String
  data        Json
  status      String    @default("draft")
  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [company_id], references: [id])

  @@index([tenant_id])
}

model TaskQueue {
  id          String    @id @default(cuid())
  tenant_id   String
  type        String
  payload     Json
  status      String    @default("pending")
  priority    Int       @default(1)
  retryCount  Int       @default(0)
  nextRetryAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenant_id])
  @@index([status])
  @@index([nextRetryAt])
}

model VATRegister {
  id               String   @id @default(cuid())
  tenant_id        String
  company_id       String
  type             String
  period           String
  counterpartyName String
  counterpartyNIP  String?
  invoiceNumber    String
  invoiceDate      DateTime
  netAmount        Float
  vatAmount        Float
  vatRate          Float
  gtuCode          String?
  documentType     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company  @relation(fields: [company_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
  @@index([period])
  @@index([type])
}

model TaxCalculation {
  id                 String    @id @default(cuid())
  tenant_id          String
  company_id         String
  period             String
  declarationType    String
  totalRevenue       Float     @default(0)
  vatCollectedSales  Float     @default(0)
  vatPaidPurchases   Float     @default(0)
  vatDue             Float     @default(0)
  totalCosts         Float     @default(0)
  taxDeductibleCosts Float     @default(0)
  taxableIncome      Float     @default(0)
  taxBase            Float     @default(0)
  taxDue             Float     @default(0)
  previousAdvance    Float     @default(0)
  advanceToPay       Float     @default(0)
  status             String    @default("draft")
  calculatedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  company            Company   @relation(fields: [company_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
  @@index([period])
  @@index([declarationType])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenant_id  String
  company_id String?
  user_id    String?
  action     String
  entity     String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())
  company    Company? @relation(fields: [company_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
  @@index([createdAt])
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  tenant_id String
  name      String
  type      String
  title     String
  body      String
  variables String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenant_id])
  @@index([type])
}

model Notification {
  id            String    @id @default(cuid())
  tenant_id     String
  user_id       String
  type          String
  title         String
  body          String
  data          Json?
  priority      String    @default("normal")
  status        String    @default("pending")
  scheduledFor  DateTime?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenant_id])
  @@index([user_id])
  @@index([status])
  @@index([scheduledFor])
}

model DeadlineReminder {
  id           String    @id @default(cuid())
  tenant_id    String
  deadlineId   String
  user_id      String
  reminderType String
  scheduledFor DateTime
  sent         Boolean   @default(false)
  sentAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([tenant_id])
  @@index([user_id])
  @@index([deadlineId])
  @@index([scheduledFor])
}

model DeadlineCompletion {
  id          String   @id @default(cuid())
  tenant_id   String
  deadlineId  String
  user_id     String
  completedAt DateTime @default(now())
  notes       String?

  @@index([tenant_id])
  @@index([deadlineId])
  @@index([user_id])
}

model OfficialCommunication {
  id               String    @id @default(cuid())
  tenant_id        String
  company_id       String
  type             String
  entityType       String
  entityId         String
  status           String
  direction        String
  officialBody     String
  referenceNumber  String?
  upoNumber        String?
  description      String
  content          Json
  responseRequired Boolean   @default(false)
  responseDeadline DateTime?
  respondedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenant_id])
  @@index([company_id])
  @@index([entityType])
  @@index([entityId])
  @@index([officialBody])
  @@index([status])
  @@index([createdAt])
}

model DataProcessingRecord {
  id               String         @id @default(cuid())
  tenant_id        String
  dataSubjectId    String
  dataCategory     String
  purpose          String
  legalBasis       String
  startDate        DateTime
  endDate          DateTime?
  status           String
  consentId        String?
  withdrawalDate   DateTime?
  withdrawalReason String?
  metadata         Json?
  additionalData   Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  consent          ConsentRecord? @relation(fields: [consentId], references: [id])

  @@index([tenant_id])
  @@index([dataSubjectId])
  @@index([consentId])
  @@index([status])
}

model ConsentRecord {
  id                   String            @id @default(cuid())
  tenant_id            String
  dataSubjectId        String
  templateId           String?
  purposes             String[]
  legalBasis           String
  consentMethod        String
  consentText          String
  consentDate          DateTime
  ipAddress            String?
  userAgent            String?
  location             String?
  status               String
  withdrawalDate       DateTime?
  withdrawalReason     String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  template             ConsentTemplate?  @relation(fields: [templateId], references: [id])
  dataProcessingRecords DataProcessingRecord[]

  @@index([tenant_id])
  @@index([dataSubjectId])
  @@index([templateId])
  @@index([status])
}

model PrivacyNotice {
  id             String                 @id @default(cuid())
  tenant_id      String
  title          String
  version        String
  content        String
  summary        String
  language       String
  effectiveDate  DateTime
  isActive       Boolean                @default(true)
  noticeType     String
  targetAudience String
  jurisdictions  String[]
  createdBy      String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  sections       PrivacyNoticeSection[]
  views          PrivacyNoticeView[]

  @@index([tenant_id])
  @@index([noticeType])
  @@index([isActive])
}

model PrivacyNoticeSection {
  id          String        @id @default(cuid())
  noticeId    String
  title       String
  content     String
  order       Int
  sectionType String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  notice      PrivacyNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@index([noticeId])
}

model PrivacyNoticeView {
  id              String        @id @default(cuid())
  noticeId        String
  userId          String?
  ipAddress       String?
  userAgent       String?
  viewedAt        DateTime
  acceptedAt      DateTime?
  acceptanceToken String?
  createdAt       DateTime      @default(now())
  notice          PrivacyNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@index([noticeId])
  @@index([userId])
  @@index([viewedAt])
}

model SecurityAudit {
  id              String   @id @default(cuid())
  tenant_id       String
  type            String
  status          String
  severity        String
  title           String
  description     String
  findings        Json?
  recommendations Json?
  evidence        Json?
  timestamp       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenant_id])
  @@index([type])
  @@index([status])
  @@index([timestamp])
}

model ComplianceReport {
  id           String   @id @default(cuid())
  tenant_id    String
  overallScore Float
  periodStart  DateTime
  periodEnd    DateTime
  summary      Json
  trends       Json
  checks       Json
  generatedAt  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenant_id])
  @@index([generatedAt])
}

model AnomalyAlert {
  id          String    @id @default(cuid())
  tenant_id   String
  ruleId      String
  userId      String?
  companyId   String?
  type        String
  severity    String
  description String
  evidence    Json
  detectedAt  DateTime
  status      String
  resolvedAt  DateTime?
  resolvedBy  String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenant_id])
  @@index([ruleId])
  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([detectedAt])
}

model UserBehaviorProfile {
  userId              String   @id
  tenant_id           String
  companyId           String
  baselineLoginTimes  Json
  baselineActions     Json
  baselineDataAccess  Json
  geographicLocations Json
  deviceFingerprints  Json
  riskScore           Float
  lastUpdated         DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenant_id])
  @@index([companyId])
}

model ConsentTemplate {
  id            String          @id @default(cuid())
  tenant_id     String
  name          String
  title         String
  content       String
  purposes      String[]
  legalBasis    String
  consentMethod String
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  consents      ConsentRecord[]

  @@index([tenant_id])
  @@index([isActive])
}

model DPIADocument {
  id                   String         @id @default(cuid())
  tenant_id            String
  company_id           String
  processingActivity   String
  assessor             String
  assessmentDate       DateTime
  status               String
  conclusion           Json?
  createdBy            String
  reviewerId           String?
  approverId           String?
  submittedForReviewAt DateTime?
  approvedAt           DateTime?
  approvalNotes        String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  activities           DPIAActivity[]
  company              Company        @relation(fields: [company_id], references: [id])
  sections             DPIASection[]

  @@index([tenant_id])
  @@index([company_id])
  @@index([status])
}

model DPIASection {
  id          String       @id @default(cuid())
  documentId  String
  sectionName String
  content     Json
  order       Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  document    DPIADocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model DPIAActivity {
  id              String       @id @default(cuid())
  documentId      String
  activityName    String
  description     String
  riskLevel       String
  mitigationSteps Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  document        DPIADocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model RiskAssessment {
  id                 String   @id @default(cuid())
  tenant_id          String
  documentId         String
  riskCategory       String
  riskDescription    String
  likelihood         String
  impact             String
  riskLevel          String
  mitigationMeasures Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenant_id])
  @@index([documentId])
}

model MitigationMeasure {
  id          String    @id @default(cuid())
  tenant_id   String
  riskId      String
  measure     String
  responsible String
  deadline    DateTime?
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenant_id])
  @@index([riskId])
}

model ComplianceCheck {
  id              String   @id @default(cuid())
  tenant_id       String
  checkId         String
  name            String
  category        String
  status          String
  severity        String
  findings        Json?
  recommendations Json?
  lastChecked     DateTime
  nextCheckDue    DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenant_id])
  @@index([checkId])
  @@index([category])
  @@index([status])
}

model PrivacySettings {
  dataSubjectId           String   @id
  tenant_id               String
  dataSharing             Boolean  @default(false)
  marketingCommunications Boolean  @default(false)
  analyticsTracking       Boolean  @default(false)
  thirdPartyCookies       Boolean  @default(false)
  dataRetention           Int      @default(365)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([tenant_id])
}

model DataBreachRecord {
  id                           String    @id @default(cuid())
  tenant_id                    String
  type                         String
  severity                     String
  description                  String
  affectedDataSubjects         Int
  affectedDataCategories       String[]
  reportedDate                 DateTime
  detectionDate                DateTime
  containmentDate              DateTime?
  notificationDate             DateTime?
  supervisoryAuthorityNotified Boolean   @default(false)
  dataSubjectsNotified         Boolean   @default(false)
  mitigationSteps              Json?
  status                       String
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@index([tenant_id])
  @@index([type])
  @@index([severity])
  @@index([reportedDate])
}

model TaxForm {
  id              String               @id @default(cuid())
  name            String
  code            String               @unique
  description     String
  category        String
  isActive        Boolean              @default(true)
  validFrom       DateTime
  validTo         DateTime?
  parameters      Json
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  companySettings CompanyTaxSettings[]
  rules           TaxRule[]

  @@index([category])
  @@index([isActive])
}

model TaxRule {
  id                String    @id @default(cuid())
  taxFormId         String
  name              String
  ruleType          String
  conditions        Json
  calculationMethod String
  value             Float
  minBase           Float?
  maxBase           Float?
  isDefault         Boolean   @default(false)
  priority          Int       @default(0)
  isActive          Boolean   @default(true)
  validFrom         DateTime
  validTo           DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  taxForm           TaxForm   @relation(fields: [taxFormId], references: [id], onDelete: Cascade)

  @@index([taxFormId])
  @@index([ruleType])
  @@index([isActive])
}

model CompanyTaxSettings {
  id            String    @id @default(cuid())
  tenant_id     String
  company_id    String
  taxFormId     String
  isSelected    Boolean   @default(false)
  settings      Json
  activatedAt   DateTime?
  deactivatedAt DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       Company   @relation(fields: [company_id], references: [id])
  taxForm       TaxForm   @relation(fields: [taxFormId], references: [id])

  @@unique([tenant_id, company_id, taxFormId])
  @@index([tenant_id])
  @@index([company_id])
