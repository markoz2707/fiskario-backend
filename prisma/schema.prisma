  company_id      String
  service         String   // "ksef" | "zus" | "epuap"
  clientId        String?
  clientSecret    String?  // Should be encrypted in production
  apiKey          String?  // Should be encrypted in production
  certificatePath String?
  environment     String   @default("test") // "test" | "production"
  isActive        Boolean  @default(true)
  lastTestedAt    DateTime?
  testResult      String?  // "success" | "failure"
