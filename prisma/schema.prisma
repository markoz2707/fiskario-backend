  @@index([company_id])
}

model DigitalCertificate {
  id                     String            @id @default(cuid())
  tenant_id              String
  company_id             String
  certificateType        String
  serialNumber           String
  issuer                 String
  subject                String
  validFrom              DateTime
  validTo                DateTime
  status                 String            @default("active")
  certificateData        String
  privateKey             String?
  keyAlgorithm           String
  keySize                Int
  trustedServiceProvider String?
  userIdentifier         String
  isDefault              Boolean           @default(false)
  renewalReminderDays    Int               @default(30)
  lastValidationAt       DateTime?
  validationStatus       String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  company                Company           @relation(fields: [company_id], references: [id])
  signatureRecords       SignatureRecord[]

  @@index([tenant_id])
  @@index([company_id])
  @@index([certificateType])
  @@index([status])
  @@index([userIdentifier])
  @@index([validTo])
  @@index([isDefault])
}

model SignatureRecord {
  id                 String             @id @default(cuid())
  tenant_id          String
  company_id         String
  certificate_id     String
  documentId         String
  documentType       String
  signatureType      String
  signatureFormat    String
  signatureValue     String
  signedContent      String
  signedDocument     String?
  timestamp          DateTime?
  tspProvider        String?
  validationStatus   String             @default("pending")
  validationErrors   String?
  signerName         String
  signerIdentifier   String
  signatureAlgorithm String
  hashAlgorithm      String
  isLongTermValid    Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  certificate        DigitalCertificate @relation(fields: [certificate_id], references: [id])
  company            Company            @relation(fields: [company_id], references: [id])

  @@index([tenant_id])
  @@index([company_id])
  @@index([certificate_id])
  @@index([documentId])
  @@index([documentType])
  @@index([signatureType])
  @@index([validationStatus])
  @@index([createdAt])
}

model ProfilZaufanyProfile {
