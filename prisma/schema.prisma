// ============================================================
// SRODKI TRWALE I AMORTYZACJA
// ============================================================

model FixedAsset {
  id                String              @id @default(cuid())
  tenant_id         String
  company_id        String

  name              String              // Nazwa srodka trwalego
  inventoryNumber   String              // Numer inwentarzowy
  kstCode           String?             // Kod KST (Klasyfikacja Srodkow Trwalych)
  kstGroup          String?             // Grupa KST (np. "4" = maszyny, "6" = urzadzenia techniczne)
  description       String?             // Opis dodatkowy

  acquisitionDate   DateTime            // Data nabycia
  activationDate    DateTime            // Data przyjecia do uzywania
  deactivationDate  DateTime?           // Data wycofania/likwidacji
  documentNumber    String?             // Nr dokumentu zakupu (faktura)
  sourceInvoiceId   String?             // ID faktury zakupu

  initialValue      Float               // Wartosc poczatkowa (brutto lub netto w zaleznosci od VAT)
  currentValue      Float               // Wartosc biezaca (po amortyzacji)
  improvementValue  Float               @default(0) // Wartosc ulepszen
  salvageValue      Float               @default(0) // Wartosc rezydualna

  depreciationMethod String             // LINEAR, DEGRESSIVE, ONE_TIME
  annualRate         Float              // Roczna stawka amortyzacji (np. 20 = 20%)
  monthlyRate        Float?             // Miesiezna stawka (obliczana z rocznej)
  totalDepreciation  Float              @default(0) // Suma dotychczasowej amortyzacji
  isFullyDepreciated Boolean            @default(false) // Czy w pelni zamortyzowany

  status             String             @default("ACTIVE") // ACTIVE, SOLD, LIQUIDATED, TRANSFERRED
  category           String?            // Kategoria wlasna uzytkownika

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  company            Company            @relation(fields: [company_id], references: [id])
  depreciationEntries DepreciationEntry[]

  @@index([tenant_id])
  @@index([company_id])
  @@index([status])
  @@index([kstCode])
  @@index([activationDate])
}

model DepreciationEntry {
  id              String     @id @default(cuid())
  tenant_id       String
  company_id      String
  asset_id        String

  month           Int        // Miesiac (1-12)
  year            Int        // Rok
  amount          Float      // Kwota odpisu amortyzacyjnego
  cumulativeAmount Float     // Suma amortyzacji narastajaco
  remainingValue  Float      // Wartosc netto po odpisie

  method          String     // LINEAR, DEGRESSIVE, ONE_TIME
  rate            Float      // Zastosowana stawka
  basis           Float      // Podstawa naliczenia (wartosc poczatkowa)

  kpirEntryId     String?    // Powiazanie z wpisem KPiR
  isBooked        Boolean    @default(false) // Czy zaksiegowano w KPiR

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  asset           FixedAsset @relation(fields: [asset_id], references: [id], onDelete: Cascade)
  company         Company    @relation(fields: [company_id], references: [id])

  @@unique([asset_id, month, year])
  @@index([tenant_id])
  @@index([company_id])
  @@index([asset_id])
  @@index([year, month])
  @@index([isBooked])
}

// ============================================================
// ROZLICZENIE ROCZNE PIT
// ============================================================

model AnnualTaxReturn {
  id                  String          @id @default(cuid())
  tenant_id           String
  company_id          String
  user_id             String

  year                Int
  formType            String          // PIT_36, PIT_36L, PIT_28

  // Dane z JDG (KPiR)
  businessIncome      Float           @default(0) // Przychod z dzialalnosci
  businessCosts       Float           @default(0) // Koszty uzyskania
  businessProfit      Float           @default(0) // Dochod z JDG

  // Dane z etatu (PIT-11)
  employmentIncome    Float           @default(0) // Przychod z etatu
  employmentCosts     Float           @default(0) // Koszty uzyskania z etatu
  employmentProfit    Float           @default(0) // Dochod z etatu
  employmentTaxPaid   Float           @default(0) // Zaliczki pracodawcy

  // Laczne dane
  totalIncome         Float           @default(0) // Laczny dochod
  zusDeduction        Float           @default(0) // Odliczenie skladek ZUS
  healthDeduction     Float           @default(0) // Odliczenie zdrowotnej
  otherDeductions     Float           @default(0) // Inne odliczenia od dochodu

  // Obliczenie podatku
  taxBase             Float           @default(0) // Podstawa opodatkowania
  taxCalculated       Float           @default(0) // Podatek obliczony
  taxCredits          Float           @default(0) // Ulgi od podatku (np. na dzieci)
  taxDue              Float           @default(0) // Podatek nalezny
  advancesPaid        Float           @default(0) // Zaliczki wplacone (JDG + etat)
  finalAmount         Float           @default(0) // Do zaplaty (+) lub nadplata (-)

  // Wspolne rozliczenie
  jointFiling         Boolean         @default(false)
  spouseIncome        Float?
  spouseCosts         Float?
  spouseTaxAdvances   Float?
  spousePesel         String?

  // Ryczalt (PIT-28)
  ryczaltRevenue      Float?          // Przychod dla ryczaltu
  ryczaltRate         Float?          // Stawka ryczaltu
  ryczaltTax          Float?          // Podatek ryczaltowy

  // Zalaczniki
  attachments         Json?           // PIT/B, PIT/O, PIT/D dane w JSON

  // Status i submission
  status              String          @default("DRAFT") // DRAFT, CALCULATING, READY, SUBMITTED, ACCEPTED, REJECTED, CORRECTED
  submittedAt         DateTime?
  upoNumber           String?
  xmlContent          String?

  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  company             Company         @relation(fields: [company_id], references: [id])
  deductions          TaxDeduction[]

  @@unique([tenant_id, user_id, year, formType])
  @@index([tenant_id])
  @@index([company_id])
  @@index([user_id])
  @@index([year])
  @@index([formType])
  @@index([status])
}

model TaxDeduction {
  id              String          @id @default(cuid())
  return_id       String
  type            String          // CHILD_RELIEF, INTERNET, DONATIONS, IKZE, THERMOMODERNIZATION, REHABILITATION, HEALTH_INSURANCE, BLOOD_DONATION, OTHER
  category        String          // FROM_INCOME, FROM_TAX
  description     String
  amount          Float
  documentRef     String?         // Nr dokumentu potwierdzajacego
  childName       String?         // Dla ulgi na dzieci - imie dziecka
  childPesel      String?         // PESEL dziecka
  childMonths     Int?            // Liczba miesiecy opieki

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  taxReturn       AnnualTaxReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)

  @@index([return_id])
  @@index([type])
  @@index([category])
}

model EmploymentIncome {
  id                  String    @id @default(cuid())
  tenant_id           String
  company_id          String
  user_id             String

  year                Int
  employerName        String    // Nazwa pracodawcy
  employerNip         String    // NIP pracodawcy
  employerAddress     String?   // Adres pracodawcy

  // Dane z PIT-11
  grossIncome         Float     // Przychod brutto
  taxDeductibleCosts  Float     // Koszty uzyskania przychodu
  netIncome           Float     // Dochod
  taxAdvancePaid      Float     // Zaliczka na podatek
  zusEmerytalnaEmpl   Float     @default(0) // Skladka emerytalna pracownika
  zusRentowaEmpl      Float     @default(0) // Skladka rentowa pracownika
  zusChorobowaEmpl    Float     @default(0) // Skladka chorobowa
  zusHealthEmpl       Float     @default(0) // Skladka zdrowotna

  // Metadane
  pitFormNumber       String?   // "PIT-11" lub nr korekty
  sourceMethod        String    @default("MANUAL") // MANUAL, OCR, IMPORT
  documentUrl         String?   // URL do skanu dokumentu

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  company             Company   @relation(fields: [company_id], references: [id])

  @@unique([tenant_id, user_id, year, employerNip])
  @@index([tenant_id])
  @@index([company_id])
  @@index([user_id])
  @@index([year])
}

// ============ AI CHAT ============

model ChatConversation {
  id          String        @id @default(cuid())
  tenant_id   String
  company_id  String
  user_id     String
  title       String?
  context     String?       // Kontekst rozmowy: TAX, ZUS, INVOICE, KPiR, GENERAL
  status      String        @default("ACTIVE") // ACTIVE, ARCHIVED
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  company     Company       @relation(fields: [company_id], references: [id])
  messages    ChatMessage[]

  @@index([tenant_id])
  @@index([company_id])
  @@index([user_id])
  @@index([status])
}

model ChatMessage {
  id              String           @id @default(cuid())
  conversationId  String
  role            String           // USER, ASSISTANT, SYSTEM
  content         String
  metadata        Json?            // tokensUsed, model, functionCalls etc.
  createdAt       DateTime         @default(now())
  conversation    ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}
